spring.application.name=Sistema_RH_Entra21

# Servidor
server.port=8080

# Banco de dados — copie para application.properties e ajuste as credenciais
spring.datasource.url=jdbc:postgresql://localhost:5432/SistemaRhEntra21
spring.datasource.username=postgres
spring.datasource.password=SUA_SENHA_AQUI
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true

# Flyway
spring.flyway.enabled=true
spring.flyway.baseline-on-migrate=true

# CORS — origens permitidas para o frontend (separadas por vírgula)
app.cors.allowed-origins=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000
